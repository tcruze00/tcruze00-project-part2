<!DOCTYPE html>
<html>
<head>
    <title>Project Part 2</title>

    <!-- CSS STYLING -->
    <style>
        /* Form styling */
        input, select, textarea {
            display: block;
            margin: 8px 0;
            padding: 5px;
        }

        input:invalid {
            border: 2px solid red;
        }

        input:valid {
            border: 2px solid green;
        }
    </style>
</head>

<body>

<!-- FORM SECTION -->
<h1>Project Part 2 Form</h1>

<form>

    <!-- Text input -->
    <label>Name:</label>
    <input type="text" required minlength="3">

    <!-- Email input -->
    <label>Email:</label>
    <input type="email" required>

    <!-- Date input -->
    <label>Date:</label>
    <input type="date">

    <!-- Radio buttons -->
    <label>Choose Option:</label>
    <input type="radio" name="option"> Option 1
    <input type="radio" name="option"> Option 2

    <!-- Checkbox -->
    <label>Skills:</label>
    <input type="checkbox"> HTML
    <input type="checkbox"> CSS

    <!-- Range slider -->
    <label>Experience Level:</label>
    <input type="range" min="0" max="10">

    <!-- Dropdown list -->
    <label>Country:</label>
    <select>
        <option>USA</option>
        <option>Canada</option>
    </select>

    <!-- Datalist -->
    <label>Browser:</label>
    <input list="browsers">
    <datalist id="browsers">
        <option value="Chrome">
        <option value="Firefox">
        <option value="Edge">
    </datalist>

    <!-- Textarea -->
    <label>Comments:</label>
    <textarea></textarea>

    <!-- Buttons -->
    <button type="submit">Submit</button>
    <button type="reset">Reset</button>

</form>

<!-- JAVASCRIPT SECTION -->
<script>

    // Alert
    alert("Welcome to Project Part 2");

    // Day and time
    function showTime() {
        console.log("Current time: " + new Date());
    }
    showTime();

    // Math method
    console.log(Math.random());

    // Convert number to text
    let num = 10;
    console.log(num.toString());

    // Countdown
    let count = 5;
    let timer = setInterval(function() {
        console.log(count);
        count--;

        if (count < 0) {
            clearInterval(timer);
            console.log("Done!");
        }
    }, 1000);

</script>

</body>
</html>
